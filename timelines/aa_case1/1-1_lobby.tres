dialog = "Larry Butz... my best
friend since grade school. "
continue_at_end = false
collection = []

[sub_resource type="Resource" id="Resource_ckkom"]
script = ExtResource("1_pri7v")
showname = "Phoenix"
dialog = "Our school had a saying:{p 0.5} \"[color=#f77339ff]When something smells,
it's usually the Butz.[/color]\" "
continue_at_end = false
collection = []

[sub_resource type="Resource" id="Resource_kbwmk"]
script = ExtResource("1_pri7v")
showname = "Phoenix"
dialog = "In the 23 years I've known
him, it's usually been true."
continue_at_end = false
collection = []

[sub_resource type="Resource" id="Resource_w4vk8"]
script = ExtResource("1_pri7v")
showname = "Phoenix"
dialog = "He has a knack for getting himself in trouble."
continue_at_end = false
collection = []

[sub_resource type="Resource" id="Resource_hp8eh"]
script = ExtResource("1_pri7v")
showname = "Phoenix"
dialog = "One thing I can say though:{p 0.5} it's usually not his fault.{p 0.2}
He just has terrible luck."
continue_at_end = false
collection = []

[sub_resource type="Resource" id="Resource_rni74"]
script = ExtResource("1_pri7v")
showname = "Phoenix"
dialog = "But I know better than anyone, that he's a good guy at heart."
continue_at_end = false
collection = []

[sub_resource type="Resource" id="Resource_wkwl1"]
script = ExtResource("1_pri7v")
showname = "Phoenix"
dialog = "That and I owe him one. Which is why I took the case... to clear his name."
continue_at_end = false
collection = []

[sub_resource type="Resource" id="Resource_biofi"]
